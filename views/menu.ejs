<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Menu</title>
    <link rel="stylesheet" href="/menu.css">
</head>
<body>
    <div class="app_container">
        
        <header class="header">
            <div class="profile_icon"></div>
            <h1 class="greeting">Olá, Freelancer</h1>
        </header>

        <section class="card_conta">
            <div class="card_label">
                <span>Conta</span>
                <span>></span>
            </div>
            <div class="saldo">R$ 1.500,00</div>
        </section>

        <div class="atalhos_container">
            <div class="btn_atalho">
                <div class="icon_circle">💼</div>
                <span class="btn_label">Novo Job</span>
            </div>

            <div class="btn_atalho">
                <div class="icon_circle">📊</div>
                <span class="btn_label">Extrato</span>
            </div>

            <div class="btn_atalho">
                <div class="icon_circle">⚙️</div>
                <span class="btn_label">Ajustes</span>
            </div>
        </div>

    </div>
</body>
</html> 